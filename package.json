{
  "name": "@keepass-web/argon2",
  "version": "0.1.2",
  "type": "module",
  "description": "Argon2d and Argon2id key derivation function implementation for keepass-web.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keepass-web/argon2.git"
  },
  "homepage": "https://github.com/keepass-web/argon2#readme",
  "bugs": "https://github.com/keepass-web/argon2/issues",
  "engines": {
    "node": ">=22.18.0"
  },
  "sideEffects": false,
  "exports": {
    ".": "./dist/src/index.js"
  },
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "src",
    "SPEC.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "node --eval \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "node --experimental-strip-types --test 'tests/**/*.test.ts'"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "^22.20.0",
    "typescript": "6.0.3"
  }
}
